#include <iostream>
#include <string>
using namespace std;

/**
 * Класс Toy (Детская игрушка)
 * Предметная область: Производство детских игрушек
 */
class Toy {
private:
    // Поля класса (все private согласно заданию)
    string name;                // Наименование игрушки
    string material;            // Материал изготовления
    int minAge;                 // Минимальный возраст ребенка (в годах)
    double price;               // Цена игрушки в рублях

public:
    /**
     * Конструктор по умолчанию.
     * Инициализирует поля начальными значениями.
     */
    Toy() {
        name = "Неизвестная игрушка";
        material = "Не указан";
        minAge = 0;
        price = 0.0;
        cout << "Вызван конструктор по умолчанию для объекта Toy" << endl;
    }

    /**
     * Конструктор с параметрами.
     * Принимает значения для всех полей класса.
     * @param n Наименование
     * @param m Материал
     * @param age Минимальный возраст
     * @param p Цена
     */
    Toy(string n, string m, int age, double p) {
        name = n;
        material = m;
        setMinAge(age);  // Используем сеттер для проверки возраста
        setPrice(p);     // Используем сеттер для проверки цены
        cout << "Вызван конструктор с параметрами для объекта Toy" << endl;
    }

    /**
     * Деструктор.
     * Выводит сообщение об уничтожении объекта.
     */
    ~Toy() {
        cout << "Деструктор: Игрушка \"" << name << "\" удалена из памяти." << endl;
    }

    // ========== Геттеры (получение значений) ==========

    /**
     * Геттер для наименования.
     * @return Название игрушки
     */
    string getName() {
        return name;
    }

    /**
     * Геттер для цены.
     * @return Цена игрушки
     */
    double getPrice() {
        return price;
    }

    /**
     * Геттер для минимального возраста.
     * @return Минимальный возраст
     */
    int getMinAge() {
        return minAge;
    }

    /**
     * Геттер для материала.
     * @return Материал
     */
    string getMaterial() {
        return material;
    }

    // ========== Сеттеры с валидацией (установка значений) ==========

    /**
     * Сеттер для минимального возраста.
     * Валидация: возраст не может быть отрицательным и не может превышать разумный предел (18 лет для детских игрушек).
     * @param age Новый минимальный возраст
     */
    void setMinAge(int age) {
        if (age >= 0 && age <= 18) {
            minAge = age;
        } else {
            cout << "Ошибка валидации: Возраст должен быть от 0 до 18 лет. Установлено значение по умолчанию (0)." << endl;
            minAge = 0;
        }
    }

    /**
     * Сеттер для цены.
     * Валидация: цена не может быть отрицательной и не может быть слишком большой (ограничим 1 млн. рублей).
     * @param p Новая цена
     */
    void setPrice(double p) {
        if (p >= 0 && p <= 1000000) {
            price = p;
        } else {
            cout << "Ошибка валидации: Цена должна быть от 0 до 1 000 000 руб. Установлено значение 0." << endl;
            price = 0.0;
        }
    }

    /**
     * Сеттер для материала.
     * Простая проверка, что строка не пустая.
     * @param m Новый материал
     */
    void setMaterial(string m) {
        if (!m.empty()) {
            material = m;
        } else {
            cout << "Ошибка валидации: Материал не может быть пустым. Значение не изменено." << endl;
        }
    }

    /**
     * Сеттер для наименования.
     * @param n Новое наименование
     */
    void setName(string n) {
        if (!n.empty()) {
            name = n;
        } else {
            cout << "Ошибка валидации: Название не может быть пустым. Значение не изменено." << endl;
        }
    }

    // ========== Методы, реализующие логику работы с объектом ==========

    /**
     * Метод 1: Применение наценки в процентах.
     * Увеличивает цену на заданный процент.
     * @param percent Процент наценки (должен быть положительным)
     */
    void applyMarkup(double percent) {
        if (percent > 0) {
            double increase = price * (percent / 100.0);
            price += increase;
            cout << "Применена наценка " << percent << "%. Новая цена: " << price << " руб." << endl;
        } else {
            cout << "Ошибка: Процент наценки должен быть положительным числом." << endl;
        }
    }

    /**
     * Метод 2: Проверка соответствия возрасту ребёнка.
     * Определяет, подходит ли игрушка ребёнку указанного возраста.
     * @param childAge Возраст ребёнка
     * @return true, если ребёнок может играть с игрушкой, иначе false
     */
    bool isSuitableForAge(int childAge) {
        if (childAge >= minAge) {
            cout << "Игрушка \"" << name << "\" подходит ребёнку " << childAge << " лет (минимальный возраст: " << minAge << ")." << endl;
            return true;
        } else {
            cout << "Игрушка \"" << name << "\" НЕ подходит ребёнку " << childAge << " лет. Она для детей от " << minAge << " лет." << endl;
            return false;
        }
    }

    /**
     * Метод для вывода полной информации об объекте.
     */
    void printInfo() {
        cout << "========== Информация об игрушке ==========" << endl;
        cout << "Наименование: " << name << endl;
        cout << "Материал: " << material << endl;
        cout << "Минимальный возраст: " << minAge << " лет" << endl;
        cout << "Цена: " << price << " руб." << endl;
        cout << "============================================" << endl;
    }
};

int main() {
    // Установка локали для вывода на русском языке
    setlocale(LC_ALL, "Russian");

    cout << "=== Демонстрация работы класса Toy (Детские игрушки) ===" << endl;
    cout << endl;

    // 1. Создание объекта с помощью конструктора по умолчанию
    cout << "[1] Создание объекта конструктором по умолчанию:" << endl;
    Toy toy1;
    toy1.printInfo();
    cout << endl;

    // 2. Создание объекта с помощью конструктора с параметрами
    cout << "[2] Создание объекта конструктором с параметрами:" << endl;
    Toy toy2("Конструктор LEGO", "Пластик", 6, 2500.50);
    toy2.printInfo();
    cout << endl;

    // 3. Демонстрация работы сеттеров и валидации
    cout << "[3] Тестирование сеттеров с валидацией:" << endl;
    
    // Попытка установить некорректный возраст
    cout << "Попытка установить возраст 25 лет (некорректно):" << endl;
    toy1.setMinAge(25); // Должна сработать валидация
    toy1.printInfo();

    // Попытка установить отрицательную цену
    cout << "Попытка установить цену -500 руб. (некорректно):" << endl;
    toy2.setPrice(-500); // Должна сработать валидация
    toy2.printInfo();

    // Корректная установка значений
    cout << "Корректная установка имени и материала:" << endl;
    toy1.setName("Плюшевый мишка");
    toy1.setMaterial("Хлопок");
    toy1.setMinAge(3);
    toy1.setPrice(1200.0);
    toy1.printInfo();
    cout << endl;

    // 4. Демонстрация работы метода applyMarkup (наценка)
    cout << "[4] Тестирование метода applyMarkup (наценка):" << endl;
    cout << "Текущая цена игрушки toy2: " << toy2.getPrice() << " руб." << endl;
    toy2.applyMarkup(15); // Наценка 15%
    toy2.printInfo();
    
    // Попытка применить отрицательную наценку
    cout << "Попытка применить наценку -5% (некорректно):" << endl;
    toy2.applyMarkup(-5);
    cout << endl;

    // 5. Демонстрация работы метода isSuitableForAge (проверка возраста)
    cout << "[5] Тестирование метода isSuitableForAge:" << endl;
    toy2.isSuitableForAge(5);  // Ребёнок 5 лет (должно быть false, т.к. minAge=6)
    toy2.isSuitableForAge(8);  // Ребёнок 8 лет (должно быть true)
    cout << endl;

    // 6. Демонстрация работы геттеров
    cout << "[6] Демонстрация работы геттеров:" << endl;
    cout << "Название игружки toy2 (геттер): " << toy2.getName() << endl;
    cout << "Материал игрушки toy2 (геттер): " << toy2.getMaterial() << endl;
    cout << "Цена игрушки toy2 (геттер): " << toy2.getPrice() << endl;
    cout << "Минимальный возраст toy2 (геттер): " << toy2.getMinAge() << endl;
    cout << endl;

    // Создаём третий объект для демонстрации деструктора
    cout << "[7] Создание дополнительного объекта:" << endl;
    Toy toy3("Деревянная машинка", "Дерево", 2, 800.0);
    toy3.printInfo();
    cout << endl;

    cout << "=== Конец программы. Объекты будут уничтожены деструкторами. ===" << endl;
    
    return 0;
}
