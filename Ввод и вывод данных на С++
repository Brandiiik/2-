#include <iostream>
#include <fstream>
#include <cmath>
#include <windows.h>

using namespace std;

int main()
{
    // Включаем поддержку русского языка в консоли Windows
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);
    
    double A, B, Y; // Переменные для хранения исходных данных и результата
    
    // === 1. Ввод данных с клавиатуры ===
    cout << "=== Способ 1: Ввод с клавиатуры ===" << endl;
    cout << "Введите значение A: ";
    cin >> A; // Считываем число с клавиатуры в переменную A
    cout << "Введите значение B: ";
    cin >> B; // Считываем число с клавиатуры в переменную B
    
    // Вычисление по формуле для первого способа
    Y = log2( fabs(A / (B - 1)) ) - (A * sin(A*A + B*B) ) / 2;
    
    // Вывод результата
    cout << "Результат Y = " << Y << endl << endl;
    
    
    // === 2. Ввод данных из файла ===
    cout << "=== Способ 2: Ввод из файла (input.txt) ===" << endl;
    
    ifstream fin;              // Создаем объект "входной файловый поток"
    fin.open("input.txt");      // Открываем файл input.txt
    
    if (fin) { // Проверяем, открылся ли файл успешно
        fin >> A >> B;          // Читаем из файла два числа
        cout << "Из файла считано: A = " << A << ", B = " << B << endl;
        
        // Вычисление по формуле для второго способа
        Y = log2( fabs(A / (B - 1)) ) - (A * sin(A*A + B*B) ) / 2;
        
        // Вывод результата
        cout << "Результат Y = " << Y << endl;
        
        fin.close();            // Закрываем файл
    } else {
        // Если файл не открылся (не найден, поврежден), выводим ошибку
        cout << "Ошибка! Не удалось открыть файл input.txt" << endl;
    }
    
    return 0; // Программа завершена успешно
}
